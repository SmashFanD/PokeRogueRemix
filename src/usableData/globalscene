  getBossType(waveIndex) {
    if (waveIndex % 1500 === 0) {
      return BossType.STRONGEST;
    }
    if (waveIndex % 300 === 0) {
      return BossType.STRONG;
    }
    if (waveIndex % 100 === 0) {
       return BossType.MEDIUM;
    }
    if (waveIndex % 25 === 0) {
       return BossType.WEAK;
    }
    if (waveIndex % 5 === 0) {
      return BossType.WEAKEST;
    }

    const randBossChanceAddTier = Math.min(Math.max(Math.ceil((waveIndex - 250) / 50), 0) * 2, 30);
    let boss = 0
    for (i = 0; i < 5; i++) {
      if (randInt(100) >= randBossChanceAddTier) continue
      boss++
    }
    return boss
  },

