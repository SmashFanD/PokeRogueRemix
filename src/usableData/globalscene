  addEnemyPokemon(
    species,
    level,
    trainerSlot,
    boss = BossType.NONE,
    shinyLock = false,
    dataSource,
    postProcess,
  ) {
    const pokemon = new EnemyPokemon(species, level, trainerSlot, boss, shinyLock, dataSource);
    
    if (boss !== BossType.NONE && !dataSource) {
      const secondaryIvs = getIvsFromId(randInt(4294967296));

      let ret = 0;
      if (boss >= BossType.WEAKEST && boss <= BossType.STRONGEST) {
        ret += boss
      } else if (boss >= BossType.GYM_LEADER_WEAKEST && boss <= BossType.GYM_LEADER_STRONGEST) {
        ret += 1 + (boss - 10);
      } else if (boss >= BossType.ELITE_FOUR_WEAKEST && boss <= BossType.ELITE_FOUR_STRONGEST) {
        ret += 2 + (boss - 20);
      } else if (boss >= BossType.CHAMPION_WEAKEST && boss <= BossType.CHAMPION_STRONGEST) {
        ret += 3 + (boss - 30);
      } else if (boss >= BossType.RIVAL_WEAKEST && boss <= BossType.RIVAL_STRONGEST) {
        ret += 4 + (boss - 40);
      } else if (boss >= BossType.LEGENDARY_WEAKEST && boss <= BossType.LEGENDARY_STRONGEST) {
        ret += 5 + (boss - 50);
      }

      for (let s = 0; s < pokemon.ivs.length; s++) {
        pokemon.ivs[s] = Math.round(Math.min(pokemon.ivs[s], secondaryIvs[s] + ret))
      }
    }
    if (postProcess) {
      postProcess(pokemon);
    }

    pokemon.init();
    return pokemon;
  },

