    const isWaveIndexMultipleOfFive = !(currentBattle.waveIndex % 5);
    const isWaveIndexMultipleOfFiftyMinusOne = currentBattle.waveIndex % 25 === 24;
    return isWaveIndexMultipleOfFive ||  isWaveIndexMultipleOfFiftyMinusOne;
